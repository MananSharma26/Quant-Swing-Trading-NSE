# =============================================================================
# .env.example — Copy to .env and fill in your values.
#
# SECURITY RULES:
#   - NEVER commit .env to git. It is in .gitignore.
#   - NEVER share your access token or API secret.
#   - Access tokens expire daily. Regenerate each morning.
#   - This file (.env.example) is safe to commit — it contains no real secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development
TRADING_MODE=backtest

# ---------------------------------------------------------------------------
# Zerodha credentials
# Replace these with your actual values in .env (never in this file).
# ZERODHA_ACCESS_TOKEN must be regenerated each morning via zerodha_login_helper.py.
# ---------------------------------------------------------------------------
ZERODHA_API_KEY=replace_me
ZERODHA_API_SECRET=replace_me
ZERODHA_ACCESS_TOKEN=replace_me_runtime_only

# Auto-login credentials (used by scripts/zerodha_auto_login.py only)
# ZERODHA_USER_ID: your Zerodha client ID (e.g. AB1234)
# ZERODHA_PASSWORD: your Zerodha login password
# ZERODHA_TOTP_SECRET: base32 secret key from when you set up Zerodha 2FA
#   This is NOT a 6-digit code. It is the underlying secret (looks like JBSWY3DPEHPK3PXP).
#   To get it: disable and re-enable 2FA on kite.zerodha.com → copy the secret shown.
ZERODHA_USER_ID=replace_me
ZERODHA_PASSWORD=replace_me
ZERODHA_TOTP_SECRET=replace_me

# ---------------------------------------------------------------------------
# Live trading master switch
#
# LIVE_TRADING_ENABLED: Master gate. Must be true for any live or API calls.
#   Default: false. Only set true when you intend to trade or call live APIs.
#
# GLOBAL_KILL_SWITCH: When true, all order placement raises SafetyError
#   immediately, regardless of other flags. Set to false only when ready to trade.
#   Default: true (kill switch armed at startup — disarm explicitly).
# ---------------------------------------------------------------------------
LIVE_TRADING_ENABLED=false
GLOBAL_KILL_SWITCH=true

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://trading:trading@localhost:5432/trading_engine

# ---------------------------------------------------------------------------
# Risk limits
# Set these to amounts you are comfortable losing in a single session.
# ---------------------------------------------------------------------------
MAX_DAILY_LOSS=1000
MAX_ORDER_VALUE=10000
MAX_OPEN_POSITIONS=3
MAX_ORDERS_PER_SECOND=1
MARKET_DATA_STALE_SECONDS=5

# ---------------------------------------------------------------------------
# Live order execution pilot flags
#
# ALL THREE flags below must be set to true simultaneously for real orders.
# They are independent so that each can be toggled for safety.
#
# WARNING: Setting these to true enables REAL order placement via Zerodha.
# Read docs/LIVE_PILOT_RUNBOOK.md and docs/OPERATING_CHECKLIST.md first.
#
# LIVE_ORDER_EXECUTION_ENABLED: Must be true for any order execution path.
# LIVE_ORDER_PILOT_ENABLED:     Pilot-specific gate. True enables single-share pilot.
# LIVE_MAX_ORDER_QUANTITY:      Hard cap on quantity per order. Start with 1.
#
# LIVE_ALLOWED_SYMBOLS: JSON array of tradingsymbols permitted for live orders.
#   Must be non-empty for any order to be placed.
#   Example: LIVE_ALLOWED_SYMBOLS=["RELIANCE"]
#   Multiple: LIVE_ALLOWED_SYMBOLS=["RELIANCE","INFY"]
#   IMPORTANT: Use JSON array format (not comma-separated plain text).
#
# LIVE_ALLOWED_ORDER_TYPES: JSON array of permitted order types.
#   IMPORTANT: Use JSON array format.
#   Example: LIVE_ALLOWED_ORDER_TYPES=["MARKET","LIMIT"]
#
# STATIC IP NOTE:
#   Zerodha requires API calls to originate from a whitelisted static IP.
#   Without a matching static IP, all API calls return 401 Unauthorized.
#   This engine cannot enforce static IP — you must verify it manually.
#   See docs/OPERATING_CHECKLIST.md Step 3 for instructions.
# ---------------------------------------------------------------------------
LIVE_ORDER_EXECUTION_ENABLED=false
LIVE_ORDER_PILOT_ENABLED=false
LIVE_MAX_ORDER_QUANTITY=1
LIVE_ALLOWED_SYMBOLS=[]
LIVE_ALLOWED_EXCHANGE=NSE
LIVE_ALLOWED_PRODUCT=MIS
LIVE_ALLOWED_ORDER_TYPES=["MARKET","LIMIT"]

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
CONFIG_PATH=configs/default.yaml
DATA_DIR=./data
LOG_DIR=logs
REPORT_DIR=reports

# ---------------------------------------------------------------------------
# Historical data download (scripts/download_zerodha_historical.py)
# ---------------------------------------------------------------------------
HISTORICAL_INTERVAL=5minute
HISTORICAL_FROM_DATE=
HISTORICAL_TO_DATE=
